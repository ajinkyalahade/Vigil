# Bind to localhost by default.
SC_BIND_HOST=127.0.0.1
SC_BIND_PORT=8000

# SQLite DB path (relative to repo root, unless absolute).
SC_DB_PATH=data/security-check.db

# Comma-separated origins for CORS (frontend dev server).
SC_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: require Authorization: Bearer <token> for all /api routes.
# SC_API_TOKEN=change-me

# Optional: override OSV base URL. Set empty to disable OSV queries.
SC_OSV_API_BASE=https://api.osv.dev

# Safety: deep scans are off by default.
SC_ENABLE_DEEP_SCANS=false

# AI Resolution feature (requires Anthropic API key)
# SC_ANTHROPIC_API_KEY=sk-ant-...
SC_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
SC_ANTHROPIC_MAX_TOKENS=4096
SC_ANTHROPIC_TIMEOUT_SECONDS=30

# AI Resolution rate limiting
SC_RESOLUTION_RATE_LIMIT=10  # per minute
SC_RESOLUTION_DAILY_QUOTA=100

# Feature flags
SC_DISABLE_AI_RESOLUTION=false
SC_AI_RESOLUTION_CACHE_TTL=86400  # 24 hours in seconds

# Agent execution (runs resolution steps locally on the machine)
SC_EXECUTION_ENABLED=true
SC_EXECUTION_STEP_TIMEOUT_SECONDS=60
